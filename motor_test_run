
#include "CytronMotorDriver.h"

CytronMD motor(PWM_DIR, 39, 40);  // PWM = Pin 39, DIR = Pin 40. => Make sure pins are configured correctly

void setup() {
  // put your setup code here, to run once:

}

void loop() {
  // put your main code here, to run repeatedly:
  motor.setSpeed(64);  // Run forward at 50% speed.
  delay(1000);
  
  motor.setSpeed(128);  // Run forward at full speed.
  delay(1000);

  motor.setSpeed(0);    // Stop.
  delay(1000);

  motor.setSpeed(-64);  // Run backward at 50% speed.
  delay(1000);
  
  motor.setSpeed(-128);  // Run backward at full speed.
  delay(1000);

  motor.setSpeed(0);    // Stop.
  delay(1000);
}
